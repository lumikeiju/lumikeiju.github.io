---
import SiteLayout from "../../layouts/SiteLayout.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";
import { withBasePath } from "../../lib/urls";
import { siteName } from "../../data/site";

const candidates = [
  {
    n: 1,
    name: "Editorial Split",
    key: "editorial-split",
    blurb: "Title + meta beside a tall lead image. Horizontal gallery strip."
  },
  {
    n: 2,
    name: "Cinematic Hero",
    key: "cinematic-hero",
    blurb: "Full-bleed image hero with overlay copy. Narrow prose column."
  },
  {
    n: 3,
    name: "Sidebar Rail",
    key: "sidebar-rail",
    blurb: "Sticky left rail. Long-form right column with stacked images."
  },
  {
    n: 4,
    name: "Bento Grid",
    key: "bento-grid",
    blurb: "12-column tile grid mixing copy, stats, links, and screenshots."
  }
];
---

<SiteLayout
  title={`Layout candidates | ${siteName}`}
  description="Temporary index of layout candidates."
  noindex
>
  <main id="main-content" class="shell">
    <header>
      <p class="eyebrow">Layout exploration</p>
      <h1>Project page templates</h1>
      <p class="lede">
        Four reusable templates that any project profile can opt into via its
        <code>template</code> field. Open each, toggle light/dark, and compare.
      </p>
      <ThemeToggle />
    </header>

    <ul class="grid" role="list">
      {
        candidates.map((c) => (
          <li>
            <a href={withBasePath(`/example${c.n}/`)}>
              <span class="num">0{c.n}</span>
              <span class="name">{c.name}</span>
              <code class="key">{c.key}</code>
              <span class="blurb">{c.blurb}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</SiteLayout>

<style>
  .shell {
    width: min(960px, calc(100% - 32px));
    margin: 0 auto;
    padding: 64px 0;
  }
  .eyebrow {
    margin: 0 0 12px;
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }
  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    line-height: 1.05;
  }
  .lede {
    margin: 16px 0 24px;
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 60ch;
  }
  .lede code {
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--color-surface-soft);
    border: 1px solid var(--color-line);
    font-size: 0.95em;
  }
  .grid {
    list-style: none;
    margin: 40px 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }
  .grid a {
    display: grid;
    gap: 8px;
    padding: 24px;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    background: var(--color-surface);
    text-decoration: none;
    color: var(--color-ink);
    box-shadow: 0 18px 48px var(--color-shadow);
  }
  .grid a:hover {
    border-color: var(--color-primary);
  }
  .num {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .name {
    font-size: 1.4rem;
    font-weight: 800;
  }
  .key {
    color: var(--color-muted);
    font-size: 0.85rem;
    background: var(--color-surface-soft);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 2px 6px;
    width: max-content;
  }
  .blurb {
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }
</style>
